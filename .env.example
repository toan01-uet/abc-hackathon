# FPT AI Marketplace API Configuration
# Get your API key from: https://fptcloud.com/ai-marketplace

# Your FPT AI Marketplace API key
FPT_API_KEY=your-api-key-here

# FPT Cloud API base URL
FPT_BASE_URL=https://mkp-api.fptcloud.com/v1

# LLM model to use (available models: DeepSeek-V4-Flash, gpt-oss-120b, etc.)
# DeepSeek-V4-Flash supports 200k context window and structured output
LLM_MODEL=DeepSeek-V4-Flash
